# Panchang backend: panchangJS (beatnyk77 fork, default) or mhah-panchang
# VITE_PANCHANG_BACKEND=panchangJS

# Jyotish API — beatnyk77/jyotish-api (Docker :9393) proxied in dev
#   bun run setup:vendor && bun run jyotish:docker
VITE_JYOTISH_API_URL=/jyotish-api
# VITE_JYOTISH_API_MODE=beatnyk
# VITE_JYOTISH_API_KEY=
# VITE_JYOTISH_USE_STUB=true

# Legacy bun mock (port 3001): VITE_JYOTISH_API_URL=/jyotish-api VITE_JYOTISH_API_MODE=legacy + jyotish:api:legacy
# Direct Docker URL: VITE_JYOTISH_API_URL=http://localhost:9393