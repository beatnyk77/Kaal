  "calculation_methods": {
    "reduction": {
      "algorithm": "digital_root",
      "preserve_masters": true,
      "master_numbers": [11, 22, 33],
      "reduce_masters_in_contexts": ["personal_year", "personal_month", "personal_day"]
    },
    "birth_time_number": {
      "id": "btn",
      "label": "Birth Time Number (BTN)",
      "formula": "Sum all digits of birth time HH:MM until single digit or master",
      "inputs": ["birth_hour", "birth_minute"],
      "output": "btn",
      "reduction": "digital_root_preserve_masters",
      "gg33_notes": "BTN anchors Personal Hour count. Example: 20:20 → 2+0+2+0 = 4.",
      "examples": [
        {
          "input": { "birth_time": "20:20" },
          "steps": ["2+0+2+0 = 4"],
          "result": 4
        }
      ]
    },
    "personal_year": {
      "id": "personal_year",
      "label": "GG33 Personal Year",
      "formula": "birth_month + birth_day + current_calendar_year → reduce",
      "inputs": ["birth_month", "birth_day", "current_year"],
      "output": "personal_year",
      "reduction": "digital_root (masters noted but typically reduced for cycle position)",
      "gg33_notes": "9-year cycle; year theme sets the macro tone. Universal Year runs in parallel (reduce current_year alone).",
      "examples": [
        {
          "input": { "birth_month": 5, "birth_day": 15, "current_year": 2026 },
          "steps": ["5+15+2026 = 2046", "2+0+4+6 = 12", "1+2 = 3"],
          "result": 3
        }
      ]
    },
    "personal_month": {
      "id": "personal_month",
      "label": "Personal Month",
      "formula": "personal_year + current_calendar_month → reduce",
      "inputs": ["personal_year", "current_month"],
      "output": "personal_month",
      "reduction": "digital_root"
    },
    "personal_day": {
      "id": "personal_day",
      "label": "Personal Day",
      "formula": "personal_month + current_calendar_day → reduce",
      "inputs": ["personal_month", "current_day"],
      "output": "personal_day",
      "reduction": "digital_root",
      "gg33_notes": "Primary daily timing number for personal resonance (distinct from Universal/Daily date number)."
    },
    "daily_numbers": {
      "universal_day": {
        "id": "universal_day",
        "label": "Universal Day Number",
        "formula": "current_month + current_day + current_year → reduce",
        "inputs": ["current_month", "current_day", "current_year"],
        "output": "universal_day",
        "reduction": "digital_root",
        "gg33_notes": "Collective/global flavor of the calendar day."
      },
      "date_digit_sum": {
        "id": "date_digit_sum",
        "label": "Full Date Digit Sum",
        "formula": "Sum every digit in MMDDYYYY → reduce",
        "inputs": ["current_date_digits"],
        "output": "date_digit_sum",
        "reduction": "digital_root",
        "gg33_notes": "Alternate GG33 daily read; useful for address/date synchronicities."
      },
      "personal_day_primary": {
        "id": "personal_day_primary",
        "label": "Personal Day (primary engine method)",
        "formula": "See personal_day",
        "inputs": ["birth_month", "birth_day", "current_year", "current_month", "current_day"],
        "output": "personal_day",
        "reduction": "digital_root",
        "gg33_notes": "Kaal engine uses this as the main daily number."
      }
    },
    "personal_hour": {
      "id": "personal_hour_arthouse33",
      "source": "arthouse33",
      "label": "Personal Hour (11 PM anchor)",
      "reference_anchor": "23:00 local on the previous calendar night (if now < today's 23:00, use yesterday's 23:00)",
      "window_rule": "Each Personal Hour window runs from transition_minute past clock hour H to transition_minute past H+1",
      "steps": [
        {
          "step": 1,
          "action": "Compute BTN from birth time",
          "detail": "Reduce HH:MM digits to single digit or master (11/22/33)",
          "formula": "btn = reduce_digits(birth_hour, birth_minute)"
        },
        {
          "step": 2,
          "action": "Set transition_minute",
          "detail": "Use birth minute (e.g. 20:20 → :20)",
          "formula": "transition_minute = birth_minute"
        },
        {
          "step": 3,
          "action": "Find reference 11 PM",
          "detail": "Previous 23:00 local before current moment",
          "formula": "ref_11pm = max(23:00) where ref_11pm <= now"
        },
        {
          "step": 4,
          "action": "Determine active clock hour",
          "detail": "If current minute >= transition_minute, active = current hour; else active = previous hour (wrap midnight)",
          "formula": "active_hour = minute >= transition ? hour : hour-1"
        },
        {
          "step": 5,
          "action": "Count full hours since reference",
          "detail": "Floor whole hours from ref_11pm to start of active_hour",
          "formula": "hours_since_ref = floor((active_hour_start - ref_11pm) / 1h)"
        },
        {
          "step": 6,
          "action": "Compute raw Personal Hour",
          "detail": "Add BTN + hours_since_ref + optional calibration offset",
          "formula": "raw = btn + hours_since_ref + calibration_offset"
        },
        {
          "step": 7,
          "action": "Reduce unless master",
          "detail": "If raw is 11, 22, or 33 keep; else digital root to single digit",
          "formula": "ph = preserve_master(raw)"
        },
        {
          "step": 8,
          "action": "Lookup quality tier",
          "detail": "Map ph to best | friendly | caution | neutral using arthouse33 table",
          "formula": "quality = lookup(ph)"
        }
      ],
      "quality_lookup": {
        "source": "arthouse33_personal_hours",
        "scope": "global",
        "tiers": {
          "best": [6, 8, 9, 11, 22, 33],
          "friendly": [1, 2, 7],
          "caution": [3, 5],
          "neutral": [4]
